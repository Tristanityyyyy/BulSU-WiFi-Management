PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bulsu_wifi

JWT_SECRET=

# Comma-separated list of origins allowed to call this API (CORS).
# Include both localhost and the LAN IP if phones/devices on the
# network need to reach the frontend (e.g. for the captive portal).
FRONTEND_URL=http://localhost:5173,http://192.168.88.5:5173

# MikroTik RouterOS API — used to grant/revoke real internet access and meter
# data usage per account. Leave MIKROTIK_HOST blank to disable this feature
# entirely (safe no-op default for dev machines with no router reachable).
# MIKROTIK_ACCESS_MODE is "hotspot_ip_binding" (default — requires IP > Hotspot
# to already be bound to the LAN interface) or "firewall_address_list"
# (fallback — requires manually adding one filter rule, see project docs).
MIKROTIK_HOST=
MIKROTIK_USER=
MIKROTIK_PASSWORD=
MIKROTIK_PORT=8728
MIKROTIK_ACCESS_MODE=hotspot_ip_binding
